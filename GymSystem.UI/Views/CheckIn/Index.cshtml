@{
    ViewData["Title"] = "Member Check-in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="text-center mb-0">Member Check-in</h3>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    
                    <form asp-action="CheckIn" method="post">
                        <div class="mb-3">
                            <label for="memberId" class="form-label">Member ID</label>
                            <input type="number" name="memberId" id="memberId" class="form-control"
                                   placeholder="Enter member ID" required />
                        </div>
                        <button type="submit" class="btn btn-success w-100">Check In</button>
                    </form>
                    
                    <hr />
                    
                    <div class="text-center">
                        <a asp-action="TodayCheckIns" class="btn btn-info">View Today's Check-ins</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>