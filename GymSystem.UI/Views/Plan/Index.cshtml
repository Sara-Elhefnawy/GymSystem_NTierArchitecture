@model IEnumerable<Plan>

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Membership Plans</h2>
            <p class="text-muted">Manage your gym membership packages</p>
        </div>
    </header>
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var plan in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 plan-card">
                        <div class="card-header text-white text-center py-4"
                             style="@(plan.IsActive ? "background-color: #070093;" : "background-color: #6c757d;")">
                            <h4 class="mb-0">@plan.Name</h4>
                        </div>
                        <div class="card-header text-dark-emphasis text-center py-4 ">
                            <h4 class="mb-0">Basic Plan</h4>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="text-center mb-4">
                                <div class="display-4 fw-bold text-primary-color">@plan.Price</div>
                                <small class="text-muted">EGP</small>
                            </div>

                            <div class="mb-3">
                                <p class="text-muted mb-2">
                                    <i class="bi bi-calendar-check text-primary-color me-2"></i>
                                    <strong>Duration:</strong> @plan.DurationDays
                                </p>
                                <p class="text-muted mb-3">
                                    <i class="bi bi-file-text text-primary-color me-2"></i>
                                    <strong>Description:</strong>
                                </p>
                                <p class="small">@plan.Description</p>
                            </div>

                            <div class="mt-auto">
                                <div class="d-grid gap-2">
                                    <a asp-controller="Plan" asp-action="Details" asp-route-id="@plan.Id"
                                            class="btn btn-sm @(plan.IsActive ? "btn-outline" : "btn-inactive")"
                                            style="@(!plan.IsActive ? "border-color: #6c757d;" : "")">
                                        <i class="bi bi-eye me-1"></i>View Details
                                    </a>

                                    <div class="d-flex gap-2">
                                        <a asp-controller="Plan" asp-action="Edit" asp-route-id="@plan.Id"
                                                class="btn btn-sm flex-fill @(plan.IsActive ? "btn-outline" : "btn-inactive")"
                                                style="@(!plan.IsActive ? "border-color: #6c757d;":"")">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </a>
        
                                        <form asp-controller="Plan" asp-action="Activate" asp-route-id="@plan.Id" method="post" class="flex-fill">
                                            @if (plan.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm w-100 btn-outline">
                                                    <i class="bi bi-x-circle me-1"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm w-100 btn-inactive"
                                                        style="@(!plan.IsActive ? "border-color: #6c757d;" : "")">
                                                    <i class="bi bi-check-circle me-1"></i> Activate
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Plans Available</h4>
        </div>
    }
</div>
